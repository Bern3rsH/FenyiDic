# Optional telemetry. Leave empty to disable.
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Set to 1/true/yes to force-disable Sentry and PostHog.
VITE_TELEMETRY_DISABLED=

# Set to 1/true/yes to print telemetry network diagnostics in the terminal.
VITE_TELEMETRY_DEBUG=
